# 로컬 실행용 - 이 파일을 .env로 복사하고 값을 채우세요. (.env는 git에 커밋되지 않습니다)
# GitHub Actions에서 자동 실행할 때는 이 값들을 리포지토리 Secrets로 등록합니다 (README.md 참고).

DRIVE_FOLDER_ID_COSTCO=여기에_코스트코_구글드라이브_폴더_ID_입력
DRIVE_FOLDER_ID_TRADERS=여기에_트레이더스_구글드라이브_폴더_ID_입력
SPREADSHEET_ID=여기에_구글시트_ID_입력
SHEET_NAME=시트1

AZURE_VISION_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_VISION_KEY=여기에_Azure_키_입력

# 서비스 계정 인증 방법 1: JSON 파일 경로 (로컬 실행 시 편리)
SERVICE_ACCOUNT_FILE=service_account.json

# 서비스 계정 인증 방법 2: JSON 내용을 통째로 문자열로 (GitHub Actions Secrets용)
# 로컬에서는 보통 SERVICE_ACCOUNT_FILE만 쓰면 되므로 비워두면 됩니다.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type": "service_account", ...}

# 선택 설정 (기본값 그대로 써도 됨)
# AZURE_MAX_CALLS_PER_MINUTE=18
# CONCURRENT_WORKERS=4
# CONFIDENCE_THRESHOLD=0.65
# LOW_CONFIDENCE_WORD_RATIO=0.15
